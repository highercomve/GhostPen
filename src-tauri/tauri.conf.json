{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GhostPen",
  "version": "0.1.2",
  "identifier": "com.ghostpen.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "GhostPen",
        "width": 320,
        "height": 620,
        "decorations": false,
        "transparent": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "center": true,
        "visible": false
      },
      {
        "label": "settings",
        "title": "GhostPen Settings",
        "url": "index.html#/settings",
        "width": 540,
        "height": 680,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "visible": false
      },
      {
        "label": "playground",
        "title": "GhostPen Playground",
        "url": "index.html#/playground",
        "width": 640,
        "height": 620,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "visible": false
      },
      {
        "label": "dictation",
        "title": "GhostPen Dictation",
        "url": "index.html#/dictation",
        "width": 520,
        "height": 200,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "resizable": false,
        "visible": false
      },
      {
        "label": "captions",
        "title": "GhostPen Captions",
        "url": "index.html#/captions",
        "width": 900,
        "height": 170,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "resizable": true,
        "focus": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
